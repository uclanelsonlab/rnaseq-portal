library(ggplot2)
# Your data
data <- data.frame(
sample = c("referencia", "no_bed_1", "bed_default", "bed_80", "bed_60", "bed_40", "bed_20", "bed_1"),
bnd = c(2790, 1443, 1789, 752, 732, 711, 694, 663),
del = c(5371, 4923, 5282, 5118, 5008, 4932, 4865, 4768),
dup = c(1184, 839, 1158, 1059, 969, 905, 845, 757),
ins = c(1914, 1914, 1948, 1948, 1948, 1948, 1948, 1948),
total = c(11259, 9119, 10177, 8877, 8657, 8496, 8352, 8136)
)
# Reshape to long format
data_long <- pivot_longer(data, cols = -sample, names_to = "variant_type", values_to = "count")
ggplot(data_long, aes(x = sample, y = count, fill = variant_type)) +
geom_bar(stat = "identity", position = position_dodge()) +
labs(title = "Variant Distribution Across Samples",
x = "Sample",
y = "Count",
fill = "Variant Type") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggplot(data_long, aes(x = sample, y = count, fill = variant_type)) +
geom_bar(stat = "identity") +
labs(title = "Variant Distribution Across Samples",
x = "Sample",
y = "Count",
fill = "Variant Type") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
ggplot(data_long, aes(x = sample, y = count, fill = sample)) +
geom_bar(stat = "identity") +
facet_wrap(~variant_type, scales = "free_y") +
labs(title = "Variant Counts by Type and Sample",
x = "Sample",
y = "Count") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1),
legend.position = "none")
library(tidyr)
library(ggplot2)
# Your data
data <- data.frame(
sample = c("referencia", "no_bed_1", "bed_default", "bed_80", "bed_60", "bed_40", "bed_20", "bed_1"),
bnd = c(2790, 1443, 1789, 752, 732, 711, 694, 663),
del = c(5371, 4923, 5282, 5118, 5008, 4932, 4865, 4768),
dup = c(1184, 839, 1158, 1059, 969, 905, 845, 757),
ins = c(1914, 1914, 1948, 1948, 1948, 1948, 1948, 1948),
total = c(11259, 9119, 10177, 8877, 8657, 8496, 8352, 8136)
)
# Reshape to long format
data_long <- pivot_longer(data, cols = -sample, names_to = "variant_type", values_to = "count")
# Define custom colors
variant_colors <- c(
"bnd" = "#1f77b4",    # Blue
"del" = "#ff7f0e",    # Orange
"dup" = "#2ca02c",    # Green
"ins" = "#d62728",    # Red
"total" = "#9467bd"   # Purple
)
ggplot(data_long, aes(x = sample, y = count, fill = variant_type)) +
geom_bar(stat = "identity", position = position_dodge(width = 0.8)) +
geom_text(
aes(label = count),
position = position_dodge(width = 0.8),
vjust = -0.5,        # Adjust vertical position (above bars)
size = 3,            # Label size
color = "black"      # Label color
) +
scale_fill_manual(values = variant_colors, name = "Variant Type") +
labs(
title = "Variant Distribution Across Samples",
x = "Sample",
y = "Count"
) +
theme_minimal() +
theme(
axis.text.x = element_text(angle = 45, hjust = 1, size = 10),
legend.position = "top"
) +
ylim(0, max(data_long$count) * 1.1)  # Add space for labels
